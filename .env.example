PINECONE_API_KEY=
PINECONE_HOST=
SUPABASE_URL=https://zonhaprelkjyjugpqfdn.supabase.co
SUPABASE_ANON_KEY=  # optional; default in code for project zonhaprelkjyjugpqfdn

# Fallbacks if SUPABASE_* not set (same as VITE_* for local dev)
VITE_SUPABASE_URL=https://zonhaprelkjyjugpqfdn.supabase.co
VITE_SUPABASE_ANON_KEY=  # optional; default in code

# Frontend — backend API URL (default: http://localhost:3002)
VITE_API_URL=http://localhost:3002
