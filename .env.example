# Copy to .env and fill with your keys
# .env is gitignored — never commit real API keys
# Optional: .env.local (same folder) overrides .env for local dev — the server loads both.
#
# Local dev: one command starts API + frontend together:
#   npm run dev
#   (same as: npm start)  →  Express (api) + Vite (web), same terminal. Ctrl+C stops both.

# Backend (server) — OpenAI + Pinecone (required for /api/submit-profile and /api/update-profile to upsert vectors)
# Server also reads VITE_OPENAI_* / VITE_PINECONE_* if these are empty (same values OK).
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_HOST=
# Optional duplicates for Vite-only keys — server will fall back to these:
# VITE_OPENAI_API_KEY=
# VITE_PINECONE_API_KEY=
# VITE_PINECONE_HOST=

# Set to 1 to enable GET /api/health/pinecone-probe?debug=1 (tests OpenAI embed + Pinecone upsert)
# PINECONE_DEBUG=1
#
SUPABASE_URL=https://zonhaprelkjyjugpqfdn.supabase.co
SUPABASE_ANON_KEY=  # optional; default in code for project zonhaprelkjyjugpqfdn
# Only for /api/upload-image (server-side storage). Not used for ai_summary (that uses RPC + anon key).
SUPABASE_SERVICE_ROLE_KEY=

# Fallbacks if SUPABASE_* not set (same as VITE_* for local dev)
VITE_SUPABASE_URL=https://zonhaprelkjyjugpqfdn.supabase.co
VITE_SUPABASE_ANON_KEY=  # optional; default in code

# Local dev: backend port (Express) and Vite dev server port — keep these aligned with VITE_API_URL
BACKEND_PORT=4000
FRONTEND_PORT=5174

# Optional: protect POST /api/regenerate-ai-summary with header x-regenerate-ai-summary-secret
# REGENERATE_AI_SUMMARY_SECRET=

# Optional: base URL for scripts/backfill-ai-summaries.mjs (default http://localhost:BACKEND_PORT)
# BACKEND_URL=http://localhost:4000

# Frontend — full backend base URL when not using Vite proxy (production). In dev, leave empty to proxy /api to BACKEND_PORT
# VITE_API_URL=http://localhost:4000
